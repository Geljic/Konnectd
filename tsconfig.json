{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    // Set explicitly so dynamic import() typechecks regardless of what the
    // Expo SDK's tsconfig.base pins for `module` (metro/babel handle the
    // actual transpile — this only affects `tsc --noEmit`).
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src", "scripts", "*.ts", "*.tsx"],
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS",
      "moduleResolution": "node"
    }
  }
}
