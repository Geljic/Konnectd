{
  "cli": {
    "version": ">= 10.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_IAP_ENABLED": "false"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "ios": { "simulator": true },
      "env": {
        "EXPO_PUBLIC_IAP_ENABLED": "false",
        "EXPO_PUBLIC_POCKETBASE_URL": "https://konnectd.xyz"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_IAP_ENABLED": "false",
        "EXPO_PUBLIC_POCKETBASE_URL": "https://konnectd.xyz"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
