{
  "expo": {
    "name": "Konnectd",
    "slug": "konnectd",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "konnectd",
    "userInterfaceStyle": "light",
    "backgroundColor": "#CAE0D5",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash.png",
      "backgroundColor": "#CAE0D5",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "xyz.konnectd.app"
    },
    "android": {
      "package": "xyz.konnectd.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#CAE0D5"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "backgroundColor": "#0A120D",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#CAE0D5",
          "sounds": []
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3782046166009217~1103464145",
          "iosAppId": "ca-app-pub-3782046166009217~5992492038"
        }
      ]
    ]
  }
}
